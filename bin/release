#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

version=$(ruby -r ./lib/kamal/lint/version -e 'print Kamal::Lint::VERSION')

if [ -z "$version" ]; then
  echo "❌ Could not read Kamal::Lint::VERSION" >&2
  exit 1
fi

tag="v${version}"

if git rev-parse "$tag" >/dev/null 2>&1; then
  echo "❌ Tag $tag already exists" >&2
  exit 1
fi

if [ -n "$(git status --porcelain)" ]; then
  echo "❌ Working tree is dirty. Commit or stash first." >&2
  exit 1
fi

echo "→ Running tests"
bin/test

echo "→ Running rubocop"
BUNDLE_ONLY=rubocop bundle exec rubocop --parallel

echo "→ Building gem locally"
mkdir -p pkg
gem build kamal-lint.gemspec --output "pkg/kamal-lint-${version}.gem"

echo "→ Verifying the built gem installs and exec works"
sandbox="$(mktemp -d)"
trap 'rm -rf "$sandbox"' EXIT

gem install "pkg/kamal-lint-${version}.gem" \
  --install-dir "$sandbox" \
  --no-document \
  --bindir "$sandbox/bin" \
  >/dev/null

actual_version=$(GEM_HOME="$sandbox" GEM_PATH="$sandbox" "$sandbox/bin/kamal-lint" version | awk '{print $NF}')
if [ "$actual_version" != "$version" ]; then
  echo "❌ Installed gem reports version '$actual_version', expected '$version'" >&2
  exit 1
fi

actual_checks=$(GEM_HOME="$sandbox" GEM_PATH="$sandbox" "$sandbox/bin/kamal-lint" list-checks | grep -c '^[a-z][a-z0-9-]*  *')
if [ "$actual_checks" -lt 17 ]; then
  echo "❌ Installed gem only reports $actual_checks checks; expected ≥17" >&2
  exit 1
fi

echo
echo "✓ Ready to tag $tag"
echo "  Next step (manual): git tag -a $tag -m \"Release $tag\" && git push origin $tag"
echo "  The Release workflow will publish to RubyGems via OIDC trusted publishing."
